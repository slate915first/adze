{
  "name": "adze",
  "version": "15.4.0",
  "private": true,
  "description": "Adze — The Path of Awakening. A Theravāda meditation companion. Static web app with no runtime build step; this package.json exists only for dev-time tests and tooling.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/slate915first/adze.git"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:live": "PLAYWRIGHT_BASE_URL=https://adze.life playwright test --project=chromium tests/e2e/_live-diag.spec.js",
    "snapshots": "node scripts/generate-design-snapshots.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "vitest": "^2.1.8"
  }
}
